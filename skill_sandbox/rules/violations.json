{
  "catalog_version": "2026-03-24",
  "last_reviewed": "2026-03-24",
  "rules": [
    {
      "id": "prompt_override",
      "category": "prompt",
      "severity": "high",
      "description": "Attempts to override or ignore higher-priority instructions.",
      "finding_category": "policy_override",
      "subject": "instruction_priority",
      "action_state": "attempted",
      "disposition": "block",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(ignore|override|bypass)\\s+(previous|prior|above|system|developer)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM01 Prompt Injection",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "system_exfiltration",
      "category": "prompt",
      "severity": "high",
      "description": "Requests or leaks system/developer messages or hidden prompts.",
      "finding_category": "disclosure_request",
      "subject": "hidden_prompt",
      "action_state": "requested",
      "disposition": "block",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(show|reveal|dump|print|return|expose|output|extract|leak|disclose|send|share|display)\\b.{0,80}\\b(system|developer)\\s+(prompt|message|instructions)\\b",
        "\\b(system|developer)\\s+(prompt|message|instructions)\\b.{0,80}\\b(show|reveal|dump|print|return|expose|output|extract|leak|disclose|send|share|display)\\b",
        "\\breveal\\s+the\\s+system\\s+prompt\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM01 Prompt Injection",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        },
        {
          "name": "Simon Willison",
          "ref": "Prompt injection series",
          "url": "https://simonwillison.net/series/prompt-injection/"
        }
      ]
    },
    {
      "id": "secret_exfiltration",
      "category": "prompt",
      "severity": "medium",
      "description": "Requests or attempts to reveal secrets, credentials, or access tokens.",
      "finding_category": "disclosure_request",
      "subject": "credentials",
      "action_state": "requested",
      "disposition": "block",
      "status": "verified",
      "match_mode": "all",
      "patterns": [
        "\\b(show|reveal|dump|print|return|expose|display|output|extract|leak)\\b",
        "\\b(api\\s*key|access\\s+token|bearer\\s+token|password|credential|secret|access\\s+key|private\\s+key|ssh\\s+key|pem)\\b"
      ],
      "exclude_patterns": [
        "\\btoken\\s+saver\\b",
        "\\bwasted\\s+tokens\\b",
        "\\btoken\\s+budget\\b",
        "\\btoken\\s+lifecycle\\b",
        "\\bcredential\\s+exposure\\b"
      ],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM02 Sensitive Information Disclosure",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "sensitive_topic",
      "category": "context",
      "severity": "info",
      "description": "Discusses secrets, tokens, or credentials as a topic without requesting disclosure.",
      "finding_category": "topic_mention",
      "subject": "credentials",
      "action_state": "mentioned",
      "disposition": "info",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(api\\s*key|access\\s+token|bearer\\s+token|token\\s+lifecycle|credential\\s+exposure|credentials?|secrets?|private\\s+key|ssh\\s+key|pem)\\b"
      ],
      "exclude_patterns": [
        "\\b(show|reveal|dump|print|return|expose|fetch|read|display|output|extract|leak)\\b.{0,40}\\b(api\\s*key|access\\s+token|bearer\\s+token|password|credential|secret|access\\s+key|private\\s+key|ssh\\s+key|pem)\\b"
      ],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM02 Sensitive Information Disclosure",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "tool_escape",
      "category": "prompt",
      "severity": "medium",
      "description": "Instructions to invoke external tools, shells, or command execution contexts.",
      "finding_category": "execution_intent",
      "subject": "tool_execution",
      "action_state": "instructed",
      "disposition": "require_approval",
      "status": "verified",
