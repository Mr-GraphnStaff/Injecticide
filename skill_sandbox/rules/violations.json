        }
      ]
    },
    {
      "id": "autonomous_authoritative_write",
      "category": "enterprise",
      "severity": "high",
      "description": "Claims or instructs autonomous write actions against authoritative enterprise systems.",
      "finding_category": "autonomous_execution",
      "subject": "enterprise_write",
      "action_state": "described",
      "disposition": "block",
      "status": "verified",
      "match_mode": "all",
      "patterns": [
        "\\b(jira|confluence|servicenow|github|gitlab|salesforce|sharepoint)\\b",
        "\\b(create|update|modify|delete|transition|comment|worklog|write\\s+operation|write\\s+capability|write\\s+access)\\b",
        "\\b(autonom(?:ous|ously)|when\\s+triggered|trigger\\s+phrase|without\\s+human\\s+review|will\\s+create|will\\s+modify|single\\s+operation|run\\s+kill\\s+chain\\s+test|execute\\s+kill\\s+chain\\s+demonstration)\\b",
        "\\b(systems?\\s+of\\s+record|authoritative\\s+systems?|authoritative\\s+data)\\b"
      ],
      "exclude_patterns": [
        "\\balways\\s+confirm\\b.{0,80}\\b(before|prior\\s+to)\\b.{0,80}\\b(create|update|modify|delete|transition|comment|worklog)\\b",
        "\\bdraft\\b.{0,80}\\b(issue|ticket|comment)\\b"
      ],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "Authorized capability misuse / enterprise action abuse",
