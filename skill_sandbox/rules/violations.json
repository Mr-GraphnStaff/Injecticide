{
  "catalog_version": "2026-03-24",
  "last_reviewed": "2026-03-24",
  "rules": [
    {
      "id": "prompt_override",
      "category": "prompt",
      "severity": "high",
      "description": "Attempts to override or ignore higher-priority instructions.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(ignore|override|bypass)\\s+(previous|prior|above|system|developer)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM01 Prompt Injection",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "system_exfiltration",
      "category": "prompt",
      "severity": "high",
      "description": "Requests or leaks system/developer messages or hidden prompts.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(system|developer)\\s+(prompt|message|instructions)\\b",
        "\\breveal\\s+the\\s+system\\s+prompt\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM01 Prompt Injection",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        },
        {
          "name": "Simon Willison",
          "ref": "Prompt injection series",
          "url": "https://simonwillison.net/series/prompt-injection/"
        }
      ]
    },
    {
      "id": "secret_exfiltration",
      "category": "prompt",
      "severity": "medium",
      "description": "Requests secrets, tokens, or keys in prompt text.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(api\\s*key|secret|token|password|credential|access\\s+key|private\\s+key|ssh|pem)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM02 Sensitive Information Disclosure",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "tool_escape",
      "category": "prompt",
      "severity": "medium",
      "description": "Instructions to invoke external tools, shells, or command execution contexts.",
      "status": "verified",
      "match_mode": "all",
      "patterns": [
        "\\b(run|execute|launch|open)\\b",
        "\\b(shell|terminal|powershell|bash|cmd(?:\\.exe)?|python|docker|script|command)\\b"
      ],
      "exclude_patterns": [
        "\\bexecute\\s+with\\s+discipline\\b",
        "\\bexecution\\s+over\\b",
        "\\btruth\\s+over\\s+ceremony\\b"
      ],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM01 Prompt Injection",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "dynamic_exec",
      "category": "code",
      "severity": "high",
      "description": "Dynamic code execution helpers detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(exec|eval|compile)\\s*\\("
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "Execution-oriented technique mapping",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "subprocess_spawn",
      "category": "code",
      "severity": "medium",
      "description": "Process execution via subprocess or os.system.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(subprocess\\.run|subprocess\\.Popen|os\\.system)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "Execution-oriented technique mapping",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "network_calls",
      "category": "code",
      "severity": "medium",
      "description": "Network or HTTP request usage detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(requests\\.|urllib\\.|httpx\\.|socket\\.)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "External interaction / exfiltration oriented behavior",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "filesystem_access",
      "category": "code",
      "severity": "low",
      "description": "File system access or environment reads detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(open\\(|pathlib\\.|os\\.environ|os\\.listdir)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "Local system interaction",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "url_fetch",
      "category": "code",
      "severity": "medium",
      "description": "Remote fetch or download helpers detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(curl|wget|Invoke-WebRequest|fetch\\s*\\(|requests\\.get\\s*\\()\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "External interaction / download behavior",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "base64_usage",
      "category": "obfuscation",
      "severity": "medium",
      "description": "Base64 helpers or long encoded blobs detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\bbase64\\b",
        "[A-Za-z0-9+/]{80,}={0,2}"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM01 Prompt Injection",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    },
    {
      "id": "dangerous_file_ops",
      "category": "code",
      "severity": "medium",
      "description": "Potentially destructive file system operations detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(rm\\s+-rf|del\\s+/f\\s+/s|Remove-Item\\s+-Recurse|shutil\\.rmtree|chmod\\s+[0-7]{3,4})\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "Local system interaction",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "home_write",
      "category": "code",
      "severity": "low",
      "description": "Writes to home directories or user profiles detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(/home/|~/|C:\\\\Users\\\\|\\.ssh/)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "MITRE ATLAS",
          "ref": "Local system interaction",
          "url": "https://atlas.mitre.org/"
        }
      ]
    },
    {
      "id": "sensitive_keywords",
      "category": "prompt",
      "severity": "medium",
      "description": "Sensitive keywords or credential references detected.",
      "status": "verified",
      "match_mode": "any",
      "patterns": [
        "\\b(private\\s+key|ssh|pem)\\b"
      ],
      "exclude_patterns": [],
      "sources": [
        {
          "name": "OWASP Top 10 for LLM Applications",
          "ref": "LLM02 Sensitive Information Disclosure",
          "url": "https://owasp.org/www-project-top-10-for-large-language-model-applications/"
        }
      ]
    }
  ]
}
